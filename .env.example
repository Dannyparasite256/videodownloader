# =============================================================================
# Django Video Downloader - Environment Configuration
# Copy to .env and fill in production values
# =============================================================================

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Render.com — usually auto-set; also set RENDER=true on web/worker
# RENDER=true
# DJANGO_ALLOWED_HOSTS=.onrender.com
# DATABASE_URL=  (from Render Postgres)
# REDIS_URL=     (from Render Redis — also used for Celery + Channels)

# Database
# Local dev (SQLite):
DATABASE_URL=sqlite:///db.sqlite3
# Docker / production (PostgreSQL):
# DATABASE_URL=postgres://vdl:vdl_secret@db:5432/video_downloader
POSTGRES_DB=video_downloader
POSTGRES_USER=vdl
POSTGRES_PASSWORD=vdl_secret

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CHANNELS_REDIS_URL=redis://redis:6379/3

# Download settings
DOWNLOAD_ROOT=/app/media/downloads
MAX_CONCURRENT_DOWNLOADS=5
MAX_DOWNLOAD_SIZE_MB=2048
DEFAULT_BANDWIDTH_LIMIT_KBPS=0
YTDLP_SOCKET_TIMEOUT=30
YTDLP_RETRIES=3

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@videodl.local

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Site
SITE_NAME=VideoDL Pro
SITE_URL=http://localhost:8000
